APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=
HEYGEN_ORIENTATION=
HEYGEN_MAX_POLL_ATTEMPTS=60
HEYGEN_TARGET_SECONDS=20
HEYGEN_WORDS_PER_MINUTE=150
# Burned-in subtitles on the rendered video (text-to-speech only per HeyGen).
HEYGEN_CAPTION=true
HEYGEN_OPEN_CAPTION=false
# 9:16 vertical video (Reels / Shorts / TikTok). Set HEYGEN_DIMENSION_WIDTH=0 to let HeyGen choose default.
HEYGEN_DIMENSION_WIDTH=1080
HEYGEN_DIMENSION_HEIGHT=1920
# Split video script into multiple HeyGen scenes (one line or paragraph per scene).
HEYGEN_MULTI_SCENE=true
HEYGEN_MAX_SCENES=12
# auto | paragraph | line | single
HEYGEN_SCENE_SPLIT=auto

ZRNO_API_KEY=
ZRNO_BASE_URL=https://zernio.com/api
ZRNO_PLATFORMS_JSON=
ZRNO_PLATFORM=
ZRNO_ACCOUNT_ID=
# When true, appends an internal ref line to the Zerno caption (usually leave false for clean Instagram captions).
ZRNO_APPEND_UNIQUE_CAPTION_SUFFIX=false
